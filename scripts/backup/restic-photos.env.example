# restic-photos.env — environment for restic-photos.sh (systemd EnvironmentFile).
# Real file: geralt:/etc/restic-photos.env, root:root, chmod 600 — never tracked.

# Repo on yennefer's backup disk, pushed over SFTP (root SSH between nodes).
RESTIC_REPOSITORY=sftp:root@<YENNEFER_IP>:/mnt/backup/photos

# Repo encryption password. The file is chmod 600; a second copy MUST live in
# the password manager — without it the repo is unreadable ciphertext.
RESTIC_PASSWORD_FILE=/etc/restic-photos.pass

# Optional dead-man switch: Uptime-Kuma Push monitor URL, pinged after each
# successful backup run. Comment out to skip.
KUMA_PUSH_URL=<KUMA_PHOTOS_PUSH_URL>
