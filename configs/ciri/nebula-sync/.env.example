# Pi-hole connections, format: http://<host>|<password>
# <PIHOLE_ADMIN_PASSWORD> = the shared Pi-hole admin password (see docs/dns.md).
# Real file lives only in the VM: ciri:/data/stacks/nebula-sync/.env (chmod 600),
# never committed — per CLAUDE.md secrets policy.
PRIMARY=http://<LAN_PREFIX>.101|<PIHOLE_ADMIN_PASSWORD>
REPLICAS=http://<LAN_PREFIX>.201|<PIHOLE_ADMIN_PASSWORD>
