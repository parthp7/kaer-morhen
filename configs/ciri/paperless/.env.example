# Paperless stack secrets — real .env lives only at ciri:/data/stacks/paperless/.env (chmod 600).
POSTGRES_USER=paperless
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=<PAPERLESS_DB_PASSWORD>
POSTGRES_DB=paperless
# Generate: openssl rand -hex 64
PAPERLESS_SECRET_KEY=<PAPERLESS_SECRET_KEY>
# Timestamps on documents/logs; lab standard is IST everywhere.
PAPERLESS_TIME_ZONE=Asia/Kolkata
# OCR language(s), '+'-separated tesseract codes, e.g. eng+deu
PAPERLESS_OCR_LANGUAGE=eng
# Only needed behind a reverse proxy / real hostname (CSRF trusted origin):
# PAPERLESS_URL=https://<PAPERLESS_HOSTNAME>
