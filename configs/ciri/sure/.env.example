# Sure stack secrets — real .env lives only at ciri:/data/stacks/sure/.env (chmod 600).
POSTGRES_USER=sure_user
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=<SURE_DB_PASSWORD>
POSTGRES_DB=sure_production
# Generate: openssl rand -hex 64
SECRET_KEY_BASE=<SURE_SECRET_KEY_BASE>
# Optional — enables AI chat/rules, incurs OpenAI API costs. Leave commented to disable.
# OPENAI_ACCESS_TOKEN=<OPENAI_API_KEY>
