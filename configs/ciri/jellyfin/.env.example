# Copy to .env in ciri:/data/stacks/jellyfin/ and chmod 600.
# No secrets in this stack — Jellyfin's admin account is created in the web UI
# on first run and stored in ./config, not here.

# URL clients are told to use. One name works on LAN and over the tailnet
# (subnet router + split DNS → Pi-hole), so this does not need a second value.
JELLYFIN_PUBLISHED_URL=http://jellyfin.kaermorhen.internal:8096
