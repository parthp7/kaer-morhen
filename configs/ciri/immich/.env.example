# Immich .env template — real file lives only at ciri:/data/stacks/immich/.env
# (chmod 600). Env var docs: https://docs.immich.app/install/environment-variables
# This file is read both by compose (volume/env interpolation) and by the
# immich-server/-ml containers via env_file.

# Originals location — the virtiofs mount of geralt's steel/photos dataset.
# The compose fails loudly if unset.
UPLOAD_LOCATION=/mnt/photos

# Postgres credentials — used by the database container and immich-server.
# Immich restriction: A-Za-z0-9 only, no special characters or spaces.
DB_PASSWORD=<IMMICH_DB_PASSWORD>
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# House standard (memory: everything runs IST).
TZ=Asia/Kolkata
